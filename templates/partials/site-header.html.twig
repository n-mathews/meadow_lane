{#
/**
 * @file site-header.html.twig
 * Meadow Lane Park — site header and primary navigation partial.
 *
 * ALL navigation is managed through Drupal's Block layout UI.
 * Go to: Structure → Block layout → Meadow Lane Park
 *
 * Required block assignments:
 *   Primary Menu region  → Main navigation (System menu block, menu: Main)
 *   Header region        → User account menu (System menu block, menu: Account)
 *
 * The Member Login button is toggled via:
 *   Appearance → Settings → Meadow Lane Park → Show Member Login button
 */
#}
<header class="layout-header" role="banner">

  {# ── Optional utility bar ──────────────────────────── #}
  {% if page.header_top %}
    <div class="header-utility">
      <div class="header-utility__inner container">
        {{ page.header_top }}
      </div>
    </div>
  {% endif %}

  <nav class="site-nav" aria-label="{{ 'Site navigation'|t }}">

    {# ── Logo ──────────────────────────────────────────── #}
    <a class="nav__logo" href="{{ path('<front>') }}" rel="home" aria-label="{{ 'Meadow Lane Park — home'|t }}">
      <div class="nav__logo-mark" aria-hidden="true">
        {{ include('@meadow_lane/partials/logo-mark.svg.twig') }}
      </div>
      <div class="nav__brand">
        {{ 'Meadow Lane Park'|t }}
        <span class="nav__brand-sub">{{ '1000 Islands · New York'|t }}</span>
      </div>
    </a>

    {# ── Mobile hamburger toggle ────────────────────────── #}
    <button
      class="nav__toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="{{ 'Toggle navigation menu'|t }}"
    >
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>

    {# ── Primary menu ──────────────────────────────────── #}
    {# Assign: Structure → Block layout → Primary Menu region
       Block: Main navigation (System menu block, menu: Main) #}
    <ul class="nav__menu" id="primary-nav" role="list">

      {% if page.primary_menu %}
        {{ page.primary_menu }}
      {% elseif logged_in %}
        <li class="nav__admin-hint">
          <a href="{{ path('block.admin_demo', {'theme': 'meadow_lane'}) }}" class="nav__admin-hint-link">
            ⚙ {{ 'Assign a menu block to the Primary Menu region'|t }}
          </a>
        </li>
      {% endif %}

      {# Account menu — assign System menu block (Account) to Header region #}
      {% if page.header %}
        <li class="nav__menu-item nav__menu-item--account">
          {{ page.header }}
        </li>
      {% endif %}

      {# Member Login CTA — toggle in Appearance → Settings #}
      {% if show_member_login %}
        <li class="nav__menu-item">
          <a href="/member" class="nav__member-btn">{{ 'Member Login'|t }}</a>
        </li>
      {% endif %}

    </ul>

  </nav>
</header>
