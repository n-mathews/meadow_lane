{#
/**
 * @file hero-default.html.twig
 * Meadow Lane Park — default hero section content.
 *
 * Used as fallback when no block is assigned to the Hero region.
 * Included by page--front.html.twig (and optionally page.html.twig).
 *
 * Variables available from parent template:
 *   - hero_tagline: Main headline (from theme settings).
 *   - hero_subtext: Supporting paragraph (from theme settings).
 */
#}
<section class="hero" aria-label="{{ 'Welcome to Meadow Lane Park'|t }}">

  <div class="hero__scenery" aria-hidden="true">
    {{ include('@meadow_lane/partials/hero-scenery.svg.twig') }}
  </div>

  <div class="hero__content">
    <div class="hero__badge">
      <span class="hero__badge-dot"></span>
      {{ '1000 Islands, New York'|t }}
    </div>

    <h1>
      {{ hero_tagline|default('Meadow Lane Park'|t) }}<br>
      <em>{{ 'A Resident-Owned Community.'|t }}</em>
    </h1>

    <p class="hero__lead">
      {{ hero_subtext|default('A welcoming, resident-owned community nestled along the shores of the St. Lawrence River in the heart of the 1000 Islands region, New York.'|t) }}
    </p>

    <div class="hero__actions">
      <a href="/homes-for-sale" class="btn btn--white">{{ 'Explore Homes for Sale'|t }}</a>
      <a href="/about" class="btn btn--ghost-light">{{ 'Learn about us'|t }}</a>
    </div>
  </div>

</section>

{# ── Stats strip ──────────────────────────────────────── #}
<div class="stats-strip" aria-label="{{ 'Community at a glance'|t }}">
  <div class="stats-strip__item">
    <div class="stats-strip__number">{{ 'Est. 2018'|t }}</div>
    <div class="stats-strip__label">{{ 'Year founded'|t }}</div>
  </div>
  <div class="stats-strip__item">
    <div class="stats-strip__number">100%</div>
    <div class="stats-strip__label">{{ 'Resident owned'|t }}</div>
  </div>
  <div class="stats-strip__item">
    <div class="stats-strip__number">1000+</div>
    <div class="stats-strip__label">{{ 'Islands nearby'|t }}</div>
  </div>
  <div class="stats-strip__item">
    <div class="stats-strip__number">{{ '3 Seasons'|t }}</div>
    <div class="stats-strip__label">{{ 'Seasonal living'|t }}</div>
  </div>
</div>
