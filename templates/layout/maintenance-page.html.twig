{#
/**
 * @file maintenance-page.html.twig
 * Meadow Lane Park — maintenance mode page.
 *
 * Shown when the site is in maintenance mode (/admin/config/development/maintenance).
 * Uses the aerial photo as a full-bleed background with the site logo and a message.
 *
 * Variables:
 *   - logo: Site logo URL.
 *   - site_name: The site name.
 *   - content: The maintenance message (set in admin UI).
 */
#}
<!DOCTYPE html>
<html{{ html_attributes }}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ site_name }} — {{ 'Temporarily unavailable'|t }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      font-family: 'Georgia', serif;
    }

    body {
      min-height: 100vh;
      background-color: #1E2D28;
      background-image: url('{{ base_path ~ directory }}/images/hero-aerial.jpg');
      background-size: cover;
      background-position: center 40%;
      background-repeat: no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    /* Dark overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(28, 45, 38, 0.75) 0%,
        rgba(28, 45, 38, 0.88) 100%
      );
      z-index: 0;
    }

    .maintenance-card {
      position: relative;
      z-index: 1;
      max-width: 520px;
      width: 100%;
      text-align: center;
    }

    /* Logo mark */
    .maintenance-logo {
      width: 72px;
      height: auto;
      margin: 0 auto 1.5rem;
    }

    .maintenance-logo img {
      width: 72px;
      height: auto;
    }

    /* Badge */
    .maintenance-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.18);
      color: rgba(255,255,255,0.75);
      font-family: 'Georgia', serif;
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 1.5rem;
    }

    .maintenance-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #6E9E92;
      flex-shrink: 0;
    }

    /* Heading */
    .maintenance-heading {
      font-family: 'Georgia', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: normal;
      font-style: italic;
      color: white;
      line-height: 1.15;
      margin-bottom: 1.25rem;
      letter-spacing: -0.01em;
    }

    /* Message */
    .maintenance-message {
      font-family: -apple-system, 'Helvetica Neue', sans-serif;
      font-size: 1rem;
      color: rgba(255,255,255,0.65);
      line-height: 1.7;
      margin-bottom: 2rem;
    }

    .maintenance-message p { margin-bottom: 0.5em; }
    .maintenance-message p:last-child { margin-bottom: 0; }

    /* Divider */
    .maintenance-divider {
      width: 48px;
      height: 1.5px;
      background: rgba(110,158,146,0.6);
      margin: 2rem auto;
      border: none;
    }

    /* Site name */
    .maintenance-site-name {
      font-family: 'Georgia', serif;
      font-size: 1rem;
      font-weight: normal;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.06em;
    }
  </style>
</head>
<body>
  <div class="maintenance-card">

    <div class="maintenance-logo" aria-hidden="true">
      <img src="{{ base_path ~ directory }}/images/logo-icon.png"
           alt="{{ site_name }}"
           width="72" height="55"/>
    </div>

    <div class="maintenance-badge">
      <span class="maintenance-badge-dot"></span>
      {{ 'Back shortly'|t }}
    </div>

    <h1 class="maintenance-heading">
      {{ 'Temporarily<br>unavailable'|t|raw }}
    </h1>

    <div class="maintenance-message">
      {% if content %}
        {{ content }}
      {% else %}
        <p>{{ 'Meadow Lane Park\'s website is currently undergoing scheduled maintenance.'|t }}</p>
        <p>{{ 'Please check back soon.'|t }}</p>
      {% endif %}
    </div>

    <hr class="maintenance-divider">

    <p class="maintenance-site-name">
      {{ site_name }} &middot; {{ '1000 Islands, New York'|t }}
    </p>

  </div>
</body>
</html>
