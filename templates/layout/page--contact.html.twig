{#
/**
 * @file page--contact.html.twig
 * Meadow Lane Park — Contact page.
 *
 * No public-facing contact form. Prospective members contact the
 * community via phone or email listed in theme settings.
 * The page.content region can hold any additional blocks placed
 * by editors (e.g. a Webform accessible only to members later).
 */
#}
<div class="site-wrapper">

  {{ include('@meadow_lane/partials/site-header.html.twig') }}

  {# ── Page banner ──────────────────────────────────────── #}
  <div class="page-banner">
    <div class="page-banner__inner container">
      {% if page.breadcrumb %}
        <nav class="page-banner__breadcrumb" aria-label="{{ 'Breadcrumb'|t }}">
          {{ page.breadcrumb }}
        </nav>
      {% endif %}
      <span class="section-label" style="color:rgba(255,255,255,0.55);">
        {{ 'Get in touch'|t }}
      </span>
      <h1 class="page-banner__title">{{ 'Contact Us'|t }}</h1>
    </div>
  </div>

  {% if page.highlighted %}
    <div class="layout-highlighted container">{{ page.highlighted }}</div>
  {% endif %}

  <main id="main-content" class="layout-main" role="main" tabindex="-1">
    <div class="container">

      <section class="inner-page">
        <p class="inner-page__lead">
          {{ 'Interested in a seasonal home at Meadow Lane Park? We\'d love to hear from you. Reach us by phone or email and we\'ll be happy to answer any questions or arrange a visit.'|t }}
        </p>

        <div class="contact-layout">

          {# ── Contact details ───────────────────────────── #}
          <div class="contact-layout__details">

            <div class="card" style="margin-bottom: var(--space-5);">
              <span class="section-label">{{ 'Contact details'|t }}</span>
              <dl class="contact-details">
                {% if contact_address %}
                  <dt>{{ 'Address'|t }}</dt>
                  <dd><address>{{ contact_address }}</address></dd>
                {% endif %}
                {% if contact_phone %}
                  <dt>{{ 'Phone'|t }}</dt>
                  <dd><a href="tel:{{ contact_phone }}">{{ contact_phone }}</a></dd>
                {% endif %}
                {% if contact_email %}
                  <dt>{{ 'Email'|t }}</dt>
                  <dd><a href="mailto:{{ contact_email }}">{{ contact_email }}</a></dd>
                {% endif %}
              </dl>
            </div>

            <div class="card" style="margin-bottom: var(--space-5);">
              <span class="section-label">{{ 'Office hours'|t }}</span>
              <dl class="contact-details">
                <dt>{{ 'Monday – Friday'|t }}</dt>
                <dd>{{ '9:00 am – 4:00 pm'|t }}</dd>
                <dt>{{ 'Saturday'|t }}</dt>
                <dd>{{ '10:00 am – 2:00 pm'|t }}</dd>
                <dt>{{ 'Sunday'|t }}</dt>
                <dd>{{ 'Closed'|t }}</dd>
              </dl>
            </div>

            {% if social_facebook %}
              <div class="card">
                <span class="section-label">{{ 'Follow us'|t }}</span>
                <a
                  href="{{ social_facebook }}"
                  class="btn btn--outline"
                  target="_blank"
                  rel="noopener noreferrer"
                  style="width:100%; justify-content:center; margin-top: var(--space-3);"
                >
                  {{ 'Facebook'|t }}
                </a>
              </div>
            {% endif %}

          </div>

          {# ── Seasonal homes CTA ────────────────────────── #}
          <div class="contact-layout__cta">
            <div class="card card--raised" style="padding: var(--space-10);">
              <span class="section-label">{{ 'Seasonal homes'|t }}</span>
              <h2 style="font-family: var(--font-serif); font-size: var(--text-3xl); font-weight: 500; color: var(--clr-slate); margin-bottom: var(--space-4); line-height: 1.2;">
                {{ 'Looking for a seasonal home on the river?'|t }}
              </h2>
              <p style="color: var(--clr-text-mid); margin-bottom: var(--space-6);">
                {{ 'Browse our available manufactured homes for sale. Each one is member-owned on resident land — a real stake in one of the most beautiful spots in the 1000 Islands.'|t }}
              </p>
              <a href="/homes-for-sale" class="btn btn--primary" style="width:100%; justify-content:center;">
                {{ 'View homes for sale'|t }}
              </a>
              <a href="/ownership" class="btn btn--outline" style="width:100%; justify-content:center; margin-top: var(--space-3);">
                {{ 'How ownership works'|t }}
              </a>
            </div>
          </div>

        </div>{# /.contact-layout #}

        {# Any additional blocks placed by editors #}
        {% if page.content %}
          <div class="prose" style="margin-top: var(--space-12);">
            {{ page.content }}
          </div>
        {% endif %}

      </section>

    </div>{# /.container #}
  </main>

  {{ include('@meadow_lane/partials/site-footer.html.twig') }}

</div>
