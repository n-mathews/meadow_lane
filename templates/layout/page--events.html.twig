{#
/**
 * @file page--events.html.twig
 * Meadow Lane Park — member events page.
 * Shows a FullCalendar interactive calendar above an upcoming events list.
 * The calendar is fed JSON from the events View.
 */
#}
<div class="site-wrapper">

  {{ include('@meadow_lane/partials/site-header.html.twig') }}

  <div class="page-banner">
    <div class="page-banner__inner container">
      {% if page.breadcrumb %}
        <nav class="page-banner__breadcrumb" aria-label="{{ 'Breadcrumb'|t }}">
          {{ page.breadcrumb }}
        </nav>
      {% endif %}
      <span class="section-label" style="color:rgba(255,255,255,0.55);">
        {{ 'Member portal'|t }}
      </span>
      <h1 class="page-banner__title">{{ 'Community events'|t }}</h1>
    </div>
  </div>

  {% if page.highlighted %}
    <div class="layout-highlighted container">{{ page.highlighted }}</div>
  {% endif %}

  <div class="member-layout">

    {# ── Sidebar (same as portal) ─────────────────────── #}
    <aside class="member-sidebar">
      <nav class="member-nav" aria-label="{{ 'Member navigation'|t }}">
        <ul class="member-nav__list">
          <li class="member-nav__item">
            <a href="/member" class="member-nav__link">
              <svg viewBox="0 0 20 20" fill="none" width="16" height="16" aria-hidden="true"><rect x="2" y="2" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="2" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="11" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="11" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
              {{ 'Dashboard'|t }}
            </a>
          </li>
          <li class="member-nav__item">
            <a href="/announcements" class="member-nav__link">
              <svg viewBox="0 0 20 20" fill="none" width="16" height="16" aria-hidden="true"><path d="M15 7A5 5 0 005 7c0 5.83-2.5 7.5-2.5 7.5h15S15 12.83 15 7zM11.44 17.5a2 2 0 01-2.88 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ 'Announcements'|t }}
            </a>
          </li>
          <li class="member-nav__item is-active">
            <a href="/events" class="member-nav__link">
              <svg viewBox="0 0 20 20" fill="none" width="16" height="16" aria-hidden="true"><rect x="2" y="3" width="16" height="15" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 8h16M7 1v4M13 1v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              {{ 'Events'|t }}
            </a>
          </li>
          <li class="member-nav__item">
            <a href="/member/documents" class="member-nav__link">
              <svg viewBox="0 0 20 20" fill="none" width="16" height="16" aria-hidden="true"><path d="M11 2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M11 2v6h6M13 11H7M13 14H7M9 8H7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              {{ 'Documents'|t }}
            </a>
          </li>
        </ul>
      </nav>
      {% if logged_in %}
        <div class="member-sidebar__user">
          <a href="/user/logout" class="member-sidebar__logout">{{ 'Log out'|t }}</a>
        </div>
      {% endif %}
    </aside>

    <main id="main-content" class="member-main" role="main" tabindex="-1">

      {# ── FullCalendar interactive calendar ─────────── #}
      <div class="events-calendar-wrap">
        <div id="mlp-fullcalendar"></div>
      </div>

      {# ── Upcoming events list ──────────────────────── #}
      <section class="events-list-section">
        <h2 class="events-list-section__title">{{ 'Upcoming events'|t }}</h2>
        <div class="events-list">
          {{ page.content }}
        </div>
      </section>

    </main>

  </div>

  {{ include('@meadow_lane/partials/site-footer.html.twig') }}

</div>

{# FullCalendar — loaded from CDN, no install required #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script>
(function() {
  'use strict';
  document.addEventListener('DOMContentLoaded', function() {
    var el = document.getElementById('mlp-fullcalendar');
    if (!el || typeof FullCalendar === 'undefined') return;

    var calendar = new FullCalendar.Calendar(el, {
      initialView: 'dayGridMonth',
      headerToolbar: {
        left:   'prev,next today',
        center: 'title',
        right:  'dayGridMonth,listMonth'
      },
      buttonText: {
        today:     'Today',
        month:     'Month',
        list:      'List'
      },
      // Fetch events from the Drupal JSON feed
      events: '/events/feed.json',
      eventColor: '#4A7C6F',
      eventTextColor: '#ffffff',
      eventDisplay: 'block',
      height: 'auto',
      eventClick: function(info) {
        // Scroll to the matching event in the list below
        var id = info.event.id;
        var target = document.querySelector('[data-event-id="' + id + '"]');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          target.classList.add('is-highlighted');
          setTimeout(function() { target.classList.remove('is-highlighted'); }, 2000);
        }
      },
    });
    calendar.render();
  });
})();
</script>
