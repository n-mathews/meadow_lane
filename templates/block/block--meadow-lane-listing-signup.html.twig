{#
/**
 * @file block--meadow-lane-listing-signup.html.twig
 * Meadow Lane Park — "Notify me of new listings" email signup block.
 *
 * Place in the Content region on the Homes for Sale page via
 * Structure → Block layout, restricted to /homes-for-sale.
 *
 * Requires:
 *   - meadow_lane/listing-signup library (attached automatically when
 *     this block renders via hook_preprocess_block in meadow_lane.theme)
 *   - A Kit (ConvertKit) form ID configured in theme settings
 *     Appearance → Settings → Meadow Lane Park → Kit form ID
 */
#}
<div class="listing-signup" data-kit-form-id="{{ kit_form_id|default('') }}">

  <div class="listing-signup__inner">

    <div class="listing-signup__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="24" height="24">
        <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
        <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
      </svg>
    </div>

    <div class="listing-signup__text">
      <h3 class="listing-signup__heading">{{ 'Get notified of new listings'|t }}</h3>
      <p class="listing-signup__desc">{{ 'Enter your email and we\'ll let you know when a new seasonal home is listed at Meadow Lane Park.'|t }}</p>
    </div>

    <div class="listing-signup__form-area">

      {# Signup form — posts to Kit via JS, no page reload #}
      <form class="listing-signup__form" novalidate aria-label="{{ 'New listing notification signup'|t }}">
        <div class="listing-signup__field-row">
          <label for="listing-signup-email" class="sr-only">{{ 'Email address'|t }}</label>
          <input
            type="email"
            id="listing-signup-email"
            name="email_address"
            class="listing-signup__input"
            placeholder="{{ 'Your email address'|t }}"
            autocomplete="email"
            required
            aria-required="true"
          />
          <button type="submit" class="listing-signup__btn btn btn--primary">
            <span class="listing-signup__btn-label">{{ 'Notify me'|t }}</span>
            <span class="listing-signup__btn-spinner" aria-hidden="true"></span>
          </button>
        </div>
        <p class="listing-signup__error" role="alert" aria-live="polite" hidden></p>
      </form>

      {# Success state — hidden until form submitted #}
      <div class="listing-signup__success" hidden role="status" aria-live="polite">
        <svg viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true">
          <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
          <path d="M6 10L9 13L14 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ 'You\'re on the list — we\'ll email you when a new home is listed.'|t }}
      </div>

    </div>

  </div>

</div>
